{
  "name": "@exiahuang/filehub",
  "version": "1.0.0",
  "description": "FileHub: Instant Search & Preview across Private Cloud",
  "main": "dist/main/web-server.cjs",
  "type": "module",
  "author": "exiahuang",
  "license": "MIT",
  "bin": {
    "filehub-server": "dist/main/web-server.cjs"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "npm run build:main && concurrently \"vite\" \"node --watch dist/main/web-server.cjs --dev\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsup",
    "build:main:tsc": "tsc -p tsconfig.main.json",
    "start": "node dist/main/web-server.cjs"
  },
  "dependencies": {
    "@types/qrcode": "^1.5.6",
    "classnames": "^2.5.1",
    "electron-log": "^5.0.0",
    "flexsearch": "^0.7.43",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.0",
    "pdfjs-dist": "^4.0.379",
    "prismjs": "^1.29.0",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5",
    "yauzl": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@types/xlsx": "^0.0.35",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.10"
  }
}
